<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <!-- Título exibido na aba do navegador -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Meus sites favoritos</title>

  <!-- Fonte do Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ===== ESTILOS GERAIS DA PÁGINA ===== */
    body {
      font-family: 'Nunito', sans-serif;
      background-color: #f4f6f9;
      color: #333333;
      margin: 0;
      padding: 0;
    }

    /* ===== CABEÇALHO ===== */
    header {
      background-color: #2c3e50;
      color: #ffffff;
      text-align: center;
      padding: 40px 20px;
    }

    /* Título principal do cabeçalho */
    header h1 {
      font-size: 2rem;
      margin: 0;
    }

    /* Linha decorativa abaixo do título */
    header hr {
      width: 60px;
      border: none;
      border-top: 3px solid #3498db;
      margin: 16px auto 0;
    }

    /* ===== ÁREA PRINCIPAL COM OS CARDS ===== */
    main {
      max-width: 900px;
      margin: 40px auto;
      padding: 0 20px;
      display: grid;
      /* 3 colunas em telas grandes, 1 em telas pequenas */
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 24px;
    }

    /* ===== CARD DE CADA SITE ===== */
    .card {
      background-color: #ffffff;
      border-radius: 10px;
      /* Sombra suave */
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      overflow: hidden;
      /* Transição suave ao passar o mouse */
      transition: box-shadow 0.3s, transform 0.3s;
    }

    /* Efeito ao passar o mouse no card */
    .card:hover {
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.14);
      transform: translateY(-4px);
    }

    /* ===== FAIXA COLORIDA DO TOPO DO CARD ===== */
    .card-color {
      width: 100%;
      height: 100px;
    }

    /* Cor de cada site — baseada na identidade visual de cada plataforma */
    .cor-alura    { background-color: #0f62fe; } /* azul Alura */
    .cor-spotify  { background-color: #1db954; } /* verde Spotify */
    .cor-linkedin { background-color: #0077b5; } /* azul LinkedIn */
    .cor-github   { background-color: #24292e; } /* preto GitHub */
    .cor-youtube  { background-color: #ff0000; } /* vermelho YouTube */

    /* ===== AREA DE TEXTO DO CARD ===== */
    .card-body {
      padding: 16px;
    }

    /* Nome do site — usa tag h1 conforme requisito da atividade */
    .card-body h1 {
      font-size: 1.1rem;
      font-weight: 700;
      margin: 0 0 8px 0;
      color: #2c3e50;
    }

    /* Link do site — usa tag <a> conforme requisito da atividade */
    .card-body a {
      font-size: 0.85rem;
      color: #3498db;
      text-decoration: none;
      word-break: break-all;
    }

    /* Sublinhado ao passar o mouse no link */
    .card-body a:hover {
      text-decoration: underline;
    }

    /* ===== RODAPÉ ===== */
    footer {
      text-align: center;
      padding: 24px;
      font-size: 0.8rem;
      color: #888888;
      border-top: 1px solid #e0e0e0;
      margin-top: 20px;
    }
  </style>
</head>

<body>

  <!-- ===== CABEÇALHO DA PÁGINA ===== -->
  <header>
    <!-- Título com o nome do aluno — requisito da atividade -->
    <h1>Meus sites favoritos: VirgilioMike</h1>
    <!-- Linha decorativa -->
    <hr />
  </header>

  <!-- ===== GRID COM OS 5 SITES FAVORITOS ===== -->
  <main>

    <!-- ===== SITE 1: Alura ===== -->
    <div class="card">
      <!-- Faixa colorida no topo representando a cor do site -->
      <div class="card-color cor-alura"></div>

      <div class="card-body">
        <!-- Nome do site — tag h1 conforme requisito -->
        <h1>Alura</h1>

        <!-- Link abaixo — tag <a> conforme requisito -->
        <a href="https://cursos.alura.com.br" target="_blank" rel="noopener noreferrer">
          cursos.alura.com.br
        </a>
      </div>
    </div>

    <!-- ===== SITE 2: Spotify ===== -->
    <div class="card">
      <div class="card-color cor-spotify"></div>

      <div class="card-body">
        <h1>Spotify</h1>
        <a href="https://open.spotify.com/intl-pt" target="_blank" rel="noopener noreferrer">
          open.spotify.com
        </a>
      </div>
    </div>

    <!-- ===== SITE 3: LinkedIn ===== -->
    <div class="card">
      <div class="card-color cor-linkedin"></div>

      <div class="card-body">
        <h1>LinkedIn</h1>
        <a href="https://www.linkedin.com/feed/" target="_blank" rel="noopener noreferrer">
          www.linkedin.com
        </a>
      </div>
    </div>

    <!-- ===== SITE 4: GitHub ===== -->
    <div class="card">
      <div class="card-color cor-github"></div>

      <div class="card-body">
        <h1>GitHub</h1>
        <a href="https://github.com/VirgilioMike" target="_blank" rel="noopener noreferrer">
          github.com/VirgilioMike
        </a>
      </div>
    </div>

    <!-- ===== SITE 5: YouTube ===== -->
    <div class="card">
      <div class="card-color cor-youtube"></div>

      <div class="card-body">
        <h1>YouTube</h1>
        <a href="https://www.youtube.com/channel/UCoqCJ4hj0OhuyjzQ1xK-XQA" target="_blank" rel="noopener noreferrer">
          youtube.com/channel/VirgilioMike
        </a>
      </div>
    </div>

  </main>

  <!-- ===== RODAPÉ ===== -->
  <footer>
    Atividade de Desenvolvimento Web — Meus Sites Favoritos — VirgilioMike
  </footer>

</body>
</html>